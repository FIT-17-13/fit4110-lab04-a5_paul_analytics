{
  "name": "fit4110-lab04-team-analytics",
  "version": "0.1.0",
  "description": "FIT4110 Lab 04 - Docker packaging and Newman verification for Smart Campus services",
  "private": true,
  "scripts": {
    "mock:analytics": "node ./node_modules/@stoplight/prism-cli/dist/index.js mock contracts/team-analytics.openapi.yaml --host 0.0.0.0 --port 4010",
    "lint:openapi": "node ./node_modules/@stoplight/spectral-cli/dist/index.js lint contracts/team-analytics.openapi.yaml",
    "test:mock": "node ./node_modules/newman/bin/newman.js run postman/collections/team-analytics.postman_collection.json -e postman/environments/team-analytics_mock.postman_environment.json -r cli,junit,htmlextra --reporter-junit-export reports/newman-lab04-mock.xml --reporter-htmlextra-export reports/newman-lab04-mock.html",
    "test:local": "node ./node_modules/newman/bin/newman.js run postman/collections/team-analytics.postman_collection.json -e postman/environments/team-analytics_local.postman_environment.json -r cli,junit,htmlextra --reporter-junit-export reports/newman-lab04-local.xml --reporter-htmlextra-export reports/newman-lab04-local.html"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.10.0",
    "@stoplight/spectral-cli": "^6.13.1",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "wait-on": "^8.0.1"
  }
}
