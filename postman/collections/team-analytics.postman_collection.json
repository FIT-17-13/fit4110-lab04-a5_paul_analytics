{
  "info": {
    "name": "FIT4110 Lab04 Team Analytics Docker Verification",
    "description": "Postman collection for verifying the Dockerized team-analytics service in Lab 04.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET health returns 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has status ok', function () { const json = pm.response.json(); pm.expect(json.status).to.eql('ok'); });",
                  "pm.test('Response identifies analytics service', function () { const json = pm.response.json(); pm.expect(json.service).to.eql('analytics-service'); pm.expect(json).to.have.property('version'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST valid analytics event returns 201",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"iot-ingestion\",\n  \"event_type\": \"occupancy\",\n  \"location_id\": \"B1-F2-R201\",\n  \"value\": 76.5,\n  \"unit\": \"percent\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response follows accepted-event schema', function () { const json = pm.response.json(); pm.expect(json).to.have.property('event_id'); pm.expect(json.event_id).to.match(/^A-[0-9]{8}-[0-9]{4}$/); pm.expect(json).to.have.property('accepted', true); pm.expect(json.event_type).to.eql('occupancy'); pm.expect(json.risk_level).to.eql('watch'); });",
                  "const created = pm.response.json();",
                  "if (created.event_id) { pm.environment.set('createdEventId', created.event_id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "GET latest events returns items array",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/latest?location_id=B1-F2-R201&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["events", "latest"],
              "query": [
                { "key": "location_id", "value": "B1-F2-R201" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has items array', function () { const json = pm.response.json(); pm.expect(json).to.have.property('items'); pm.expect(json.items).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET event by saved event_id returns 200",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/{{createdEventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{createdEventId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response event_id matches saved variable', function () { const json = pm.response.json(); const saved = pm.environment.get('createdEventId'); pm.expect(json.event_id).to.eql(saved); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET analytics summary returns counters",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/summary?location_id=B1-F2-R201",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "summary"],
              "query": [
                { "key": "location_id", "value": "B1-F2-R201" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Summary includes counters', function () { const json = pm.response.json(); pm.expect(json).to.have.property('event_count'); pm.expect(json).to.have.property('average_value'); pm.expect(json).to.have.property('high_risk_count'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "POST event without token returns 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"iot-ingestion\",\n  \"event_type\": \"occupancy\",\n  \"location_id\": \"B1-F2-R201\",\n  \"value\": 76.5,\n  \"unit\": \"percent\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.environment.get('env') === 'mock') {",
                  "  pm.test('Mock may not enforce auth - document this behavior', function () { pm.expect([200, 201, 401, 403]).to.include(pm.response.code); });",
                  "} else {",
                  "  pm.test('Missing token returns 401', function () { pm.response.to.have.status(401); });",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('type');",
                  "  pm.expect(json).to.have.property('title');",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json.status).to.be.within(400, 599);",
                  "  pm.expect(json).to.have.property('detail');",
                  "}"
                ]
              }
            }
          ]
        },
