    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "POST boundary value 100 is accepted with warning",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"iot-ingestion\",\n  \"event_type\": \"occupancy\",\n  \"location_id\": \"B1-F2-R201\",\n  \"value\": 100,\n  \"unit\": \"percent\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Boundary value 100 returns 201', function () { pm.response.to.have.status(201); });",
                  "if (pm.environment.get('env') !== 'mock') {",
                  "  pm.test('High value response includes warning header', function () { pm.expect(pm.response.headers.has('X-Warning')).to.eql(true); });",
                  "  pm.test('Risk level is high', function () { const json = pm.response.json(); pm.expect(json.risk_level).to.eql('high'); });",
                  "}"
                ]
              }
            }
          ]
        },
